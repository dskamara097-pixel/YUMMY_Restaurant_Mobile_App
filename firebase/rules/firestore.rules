rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasProfileRole(role) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.role == 'admin' || hasProfileRole('admin'));
    }

    function isVendor() {
      return isSignedIn() && (request.auth.token.role == 'vendor' || hasProfileRole('vendor'));
    }

    function isRider() {
      return isSignedIn() && (request.auth.token.role == 'rider' || hasProfileRole('rider'));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function ownsRestaurant(restaurantId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/restaurants/$(restaurantId))
        && get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid;
    }

    function ownsRequestRestaurant() {
      return isSignedIn() && request.resource.data.restaurantId is string && ownsRestaurant(request.resource.data.restaurantId);
    }

    function ownsExistingRestaurant() {
      return isSignedIn() && resource.data.restaurantId is string && ownsRestaurant(resource.data.restaurantId);
    }

    function ownsRequestUserId() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    function ownsExistingUserId() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsRequestCustomerId() {
      return isSignedIn() && request.resource.data.customerId == request.auth.uid;
    }

    function ownsExistingCustomerId() {
      return isSignedIn() && resource.data.customerId == request.auth.uid;
    }

    function isAssignedRider() {
      return isRider() && resource.data.riderId == request.auth.uid;
    }

    function preservesOwnRoleAndStatus() {
      return request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status;
    }

    function ownsReviewRestaurant() {
      return resource.data.targetType == 'restaurant' && ownsRestaurant(resource.data.targetId);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin() || isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && preservesOwnRoleAndStatus());
      allow delete: if isAdmin() || isOwner(userId);
    }

    match /vendors/{vendorId} {
      allow read, create, update, delete: if isOwner(vendorId) || isAdmin();
    }

    match /restaurants/{restaurantId} {
      allow read: if resource.data.status == 'approved' || resource.data.active == true || isAdmin() || resource.data.ownerId == request.auth.uid;
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.ownerId == request.auth.uid);
      allow update, delete: if isAdmin() || resource.data.ownerId == request.auth.uid;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() || ownsRequestRestaurant();
      allow update, delete: if isAdmin() || ownsExistingRestaurant();
    }

    match /foods/{foodId} {
      allow read: if resource.data.available == true || isAdmin() || ownsExistingRestaurant();
      allow create: if isAdmin() || ownsRequestRestaurant();
      allow update, delete: if isAdmin() || ownsExistingRestaurant();
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow create: if isAdmin() || ownsRequestRestaurant();
      allow update, delete: if isAdmin() || ownsExistingRestaurant();
    }

    match /offers/{offerId} {
      allow read: if true;
      allow create: if isAdmin() || ownsRequestRestaurant();
      allow update, delete: if isAdmin() || ownsExistingRestaurant();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if ownsRequestUserId() || isAdmin();
      allow update: if ownsExistingUserId() || ownsReviewRestaurant() || isAdmin();
      allow delete: if ownsExistingUserId() || isAdmin();
    }

    match /orders/{orderId} {
      allow read: if ownsExistingCustomerId() || ownsExistingRestaurant() || isAssignedRider() || isAdmin();
      allow create: if ownsRequestCustomerId() || isAdmin();
      allow update: if ownsExistingCustomerId() || ownsExistingRestaurant() || isAssignedRider() || isAdmin();
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if ownsExistingUserId() || ownsExistingRestaurant() || isAdmin();
      allow create: if ownsRequestUserId() || isAdmin();
      allow update: if ownsExistingUserId() || ownsExistingRestaurant() || isAdmin();
      allow delete: if isAdmin();
    }

    match /carts/{cartId} {
      allow read, update, delete: if ownsExistingCustomerId() || isAdmin();
      allow create: if ownsRequestCustomerId() || isAdmin();
    }

    match /addresses/{addressId} {
      allow read, update, delete: if ownsExistingUserId() || isAdmin();
      allow create: if ownsRequestUserId() || isAdmin();
    }

    match /favorites/{favoriteId} {
      allow read, update, delete: if ownsExistingUserId() || isAdmin();
      allow create: if ownsRequestUserId() || isAdmin();
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if ownsExistingUserId() || isAdmin();
      allow create: if ownsRequestUserId() || isAdmin();
    }

    match /settings/{settingsId} {
      allow read, update, delete: if isAdmin() || ownsExistingUserId();
      allow create: if isAdmin() || ownsRequestUserId();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
